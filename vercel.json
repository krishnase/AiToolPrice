{
  "buildCommand": "cd site && hugo --minify",
  "outputDirectory": "site/public",
  "installCommand": "curl -L https://github.com/gohugoio/hugo/releases/download/v0.146.0/hugo_extended_0.146.0_linux-amd64.tar.gz | tar -xz -C /usr/local/bin hugo",
  "framework": null,
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ]
}